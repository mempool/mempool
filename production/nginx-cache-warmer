hostnameBitcoin=127.0.0.1:82
hostnameLiquid=127.0.0.1:83

warm()
{
	echo "$1"
	time curl -o /dev/null -s "$1"
	sleep $delay # delay between queries to not DoS mariadb
	echo
}

